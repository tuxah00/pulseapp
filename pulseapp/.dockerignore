# Docker build context'inden hariç tutulacaklar
# (build upload süresini kısaltır, image'i temiz tutar)

# Dependencies (Docker katmanında yeniden kurulacak)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js build çıktıları
.next
out
build
dist

# Git & CI
.git
.github
.gitignore
.gitattributes

# Vercel
.vercel
vercel.json

# Local env dosyaları (Coolify env vars kullanır)
.env
.env.local
.env.*.local
.env.development
.env.development.local
.env.example

# Claude / worktree
.claude
.claude-*
CLAUDE.md

# Dokümantasyon (runtime'da gerekmez)
README.md
VERCEL_PRODUCTION.md
*.md

# IDE / editor
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Test altyapısı (build sırasında gerekmez)
tests
coverage
.nyc_output
playwright-report
playwright.config.ts
test-results
vitest.config.ts

# TypeScript derleme artefactleri
*.tsbuildinfo
tsconfig.tsbuildinfo

# Log dosyaları
*.log
logs

# Supabase migration dosyaları (runtime'da gerekmez)
supabase

# Yerel script'ler (runtime'da gerekmez)
scripts

# Opsiyonel / geçici
tmp
temp
*.bak
