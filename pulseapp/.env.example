# ============================================
# PulseApp — Ortam Değişkenleri
# ============================================
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur:
#   cp .env.example .env.local
# ============================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Twilio (SMS + WhatsApp opsiyonel) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...   # İşletmenin Twilio numarası
TWILIO_WHATSAPP_NUMBER=+1...   # Twilio WA sender (sandbox: +14155238886)

# ── WhatsApp Sağlayıcı Seçimi ──
# 'twilio' (varsayılan) veya 'meta' — Meta Cloud API doğrudan Graph API kullanır (Twilio komisyonu yok)
WHATSAPP_PROVIDER=twilio

# ── Meta WhatsApp Cloud API (WHATSAPP_PROVIDER=meta ise) ──
# Meta Business Manager → WhatsApp → API Setup adımlarında alınır.
META_WA_PHONE_NUMBER_ID=           # Meta tarafından atanan phone_number_id
META_WA_ACCESS_TOKEN=              # System user permanent access token
META_WA_VERIFY_TOKEN=              # Webhook subscribe için özel string (sen belirlersin)
META_WA_APP_SECRET=                # App → Settings → Basic → App Secret (webhook imza)

# ── OpenAI (Tek AI motoru — GPT-4o Mini) ──
# Tüm AI özellikleri tek motor kullanır: sınıflandırma, yanıt, asistan,
# görsel analiz, kampanya önerisi, insights.
OPENAI_API_KEY=sk-proj-...

# ── PayTR (Ödeme) ──
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# ── Resend (E-posta) ──
RESEND_API_KEY=re_...

# ── Google ──
GOOGLE_PLACES_API_KEY=AIza...

# ── Uygulama ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=rastgele-guclu-bir-sifre

# ── Sentry (Hata Takibi) ──
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_ORG=pulseapp
SENTRY_PROJECT=pulseapp
SENTRY_AUTH_TOKEN=   # Source map upload için (opsiyonel)

# ── E2E Test (CI / lokal) ──
TEST_EMAIL=pulseapp@gmail.com
TEST_PASSWORD=123123
TEST_BUSINESS_ID=   # Gerçek business UUID
PLAYWRIGHT_BASE_URL=http://localhost:3000

# ── Seed Script ──
SEED_BUSINESS_ID=   # Seed edilecek işletme UUID'si
