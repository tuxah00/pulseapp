# ============================================
# PulseApp — Ortam Değişkenleri
# ============================================
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur:
#   cp .env.example .env.local
# ============================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Twilio (WhatsApp - Legacy, opsiyonel) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Meta WhatsApp Cloud API ──
META_APP_ID=                         # Facebook Developer App ID
META_APP_SECRET=                     # Facebook Developer App Secret
NEXT_PUBLIC_META_APP_ID=             # Client-side Meta App ID (Embedded Signup)
WHATSAPP_VERIFY_TOKEN=               # Webhook doğrulama tokeni (rastgele string)
WHATSAPP_ENCRYPTION_KEY=             # 32 byte hex: openssl rand -hex 32

# ── Claude API (Anthropic) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── PayTR (Ödeme) ──
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# ── Resend (E-posta) ──
RESEND_API_KEY=re_...

# ── Google ──
GOOGLE_PLACES_API_KEY=AIza...

# ── Uygulama ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=rastgele-guclu-bir-sifre
